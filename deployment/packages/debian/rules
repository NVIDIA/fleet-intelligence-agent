#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_build:
	cd ../../ && make bin/gpuhealth

override_dh_auto_install:
	# Install binary
	install -Dm755 ../../bin/gpuhealth debian/gpuhealth/usr/bin/gpuhealth
	
	# Install systemd service file
	install -Dm644 common/systemd/gpuhealthd.service debian/gpuhealth/lib/systemd/system/gpuhealthd.service
	
	# Install environment configuration
	install -Dm644 common/systemd/gpuhealth.env debian/gpuhealth/etc/default/gpuhealth
	
	# Create data directory
	install -dm755 debian/gpuhealth/var/lib/gpuhealth

override_dh_auto_clean:
	cd ../../ && make clean
	rm -rf ../../bin/

# Disable debhelper auto-generation of systemd scripts
override_dh_installsystemd:
	# Skip auto-generation - we handle systemd manually

 