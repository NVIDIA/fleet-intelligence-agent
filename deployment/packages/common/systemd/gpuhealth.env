# GPU Health Agent environment configuration
FLAGS="--log-level=info"
ENABLED="false"
ENDPOINT="http://localhost:8080/api/v1/health/bulk"
INTERVAL="1m"
INCLUDE_METRICS="true"
INCLUDE_EVENTS="true"
INCLUDE_MACHINE_INFO="true"
INCLUDE_COMPONENT_DATA="true"
METRICS_LOOKBACK="1m"
EVENTS_LOOKBACK="1m"
HEALTH_CHECK_INTERVAL="1m"
RETRY_MAX_ATTEMPTS="3"