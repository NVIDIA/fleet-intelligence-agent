[Unit]
Description=GPU Health Daemon
After=network.target local-fs.target

[Service]
EnvironmentFile=/etc/default/gpuhealth

ExecStart=/usr/bin/gpuhealth run $FLAGS
ExecReload=/bin/kill -HUP $MAINPID

Restart=always
RestartSec=5s
TimeoutStartSec=300
TimeoutStopSec=30

User=root
Group=root
LimitNOFILE=40000

[Install]
WantedBy=multi-user.target