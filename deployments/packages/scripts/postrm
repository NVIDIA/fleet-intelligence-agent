#!/bin/bash
set -e

case "$1" in
    remove|0)
        echo "Fleet Intelligence Agent removed (configuration preserved)"
        
        # Simple systemd cleanup
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload || echo "[WARNING] Failed to reload systemd daemon"
        fi
        
        echo "To completely remove including data: sudo apt purge fleetint"
        ;;
        
    purge)
        echo "Completely removing Fleet Intelligence Agent..."
        
        # Basic systemd cleanup
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload || echo "[WARNING] Failed to reload systemd daemon"
        fi
        
        # Remove data directory and configuration
        rm -rf /var/lib/fleetint 2>/dev/null || echo "[WARNING] Failed to remove data directory"
        rm -f /etc/default/fleetint 2>/dev/null || echo "[WARNING] Failed to remove configuration"
        
        echo "[SUCCESS] Fleet Intelligence Agent completely removed"
        ;;
        
    upgrade|1|2|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Just reload systemd for other scenarios
        if [ -d /run/systemd/system ]; then
            systemctl daemon-reload || true
        fi
        ;;
esac
