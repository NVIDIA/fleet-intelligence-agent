#!/bin/sh
set -e

case "$1" in
    install)
        if [ -z "${DPKG_ROOT:-}" ] && [ ! -d /run/systemd/system ]; then
            echo "[WARNING] Systemd not detected - service management will be limited"
        fi
        ;;
    abort-upgrade)
        echo "Aborting Fleet Intelligence Agent upgrade..."
        ;;
esac

exit 0
