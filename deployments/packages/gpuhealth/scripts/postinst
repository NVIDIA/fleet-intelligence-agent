#!/bin/bash
set -e

echo "Configuring GPU Health Agent..."

# Setup directories and permissions
mkdir -p /var/lib/gpuhealth
chmod 755 /var/lib/gpuhealth /usr/bin/gpuhealth

echo "Setting up GPU Health Agent service..."

# Handle both Debian ("configure", with optional previous version in $2)
# and RPM ($1 numeric: 1=install, 2=upgrade)
if [ ! -d /run/systemd/system ]; then
    echo "Systemd not available - manual service management required"
else
    systemctl daemon-reload || echo "[WARNING] Failed to reload systemd daemon"

    case "$1" in
        configure|install|1)
            echo "Fresh installation - enabling and starting service..."
            systemctl enable gpuhealthd.service || echo "[WARNING] Failed to enable service"
            systemctl start gpuhealthd.service || echo "[WARNING] Failed to start service"
            ;;
        upgrade|2)
            echo "Upgrade detected - (re)starting service..."
            if systemctl is-active --quiet gpuhealthd.service; then
                systemctl restart gpuhealthd.service || echo "[WARNING] Failed to restart service"
            else
                systemctl start gpuhealthd.service || echo "[WARNING] Failed to start service"
            fi
            ;;
        abort-upgrade|abort-remove|abort-deconfigure)
            if systemctl is-enabled --quiet gpuhealthd.service; then
                systemctl start gpuhealthd.service || true
            fi
            ;;
        *)
            # Fallback: try to start if enabled
            if systemctl is-enabled --quiet gpuhealthd.service; then
                systemctl start gpuhealthd.service || true
            fi
            ;;
    esac
fi

# Final status and guidance
echo ""
if [ -d /run/systemd/system ]; then
    if systemctl is-active --quiet gpuhealthd.service; then
        echo "[SUCCESS] GPU Health Agent installed and started successfully!"
        echo ""
        echo "Configuration: sudo vi /etc/default/gpuhealth"
        echo "Logs: sudo journalctl -u gpuhealthd -f"
    else
        echo "[WARNING] GPU Health Agent installed but service is not running"
        echo "Start manually: sudo systemctl start gpuhealthd"
    fi
else
    echo "[SUCCESS] GPU Health Agent installed (systemd not available)"
    echo "Manual start: /usr/bin/gpuhealth run --log-level=info"
fi
echo ""


