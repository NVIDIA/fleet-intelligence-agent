# Fleet Intelligence Agent environment configuration
FLEETINT_FLAGS="--log-level=warn --disable-local-listener"
DCGM_URL="localhost"
DCGM_URL_IS_UNIX_SOCKET="false"
FLEETINT_COLLECT_INTERVAL="1m"
FLEETINT_INCLUDE_METRICS="true"
FLEETINT_INCLUDE_EVENTS="true"
FLEETINT_INCLUDE_MACHINEINFO="true"
FLEETINT_INCLUDE_HEALTHCHECKS="true"
FLEETINT_METRICS_LOOKBACK="1m"
FLEETINT_EVENTS_LOOKBACK="1m"
FLEETINT_CHECK_INTERVAL="1m"
FLEETINT_RETRY_MAX_ATTEMPTS="3"
FLEETINT_ATTESTATION_JITTER_ENABLED="true"
FLEETINT_ATTESTATION_INTERVAL="24h"
HTTP_PROXY=""
HTTPS_PROXY=""
